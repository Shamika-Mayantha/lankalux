# Clean URLs: hide .html extension
RewriteEngine On
RewriteBase /

# Redirect .html requests to clean URLs (301) - except Google verification
RewriteCond %{THE_REQUEST} \s/(.+?)\.html[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/google [NC]
RewriteRule ^(.+?)\.html$ /$1 [R=301,L]
RewriteCond %{THE_REQUEST} \s/index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Serve the .html file when a clean URL is requested
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
